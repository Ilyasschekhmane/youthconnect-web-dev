    "prepare": "husky install"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^10.1.0",
    "husky": "^9.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "turbo": "^2.0.0"
  }
}
